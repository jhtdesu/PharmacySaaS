{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "inventory-medicines-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/medicines/{**catch-all}"
        }
      },
      "inventory-batches-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/medicinebatches/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5002" 
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5000" 
          }
        }
      }
    }
  }
}