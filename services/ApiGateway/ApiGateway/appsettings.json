{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-routes": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "inventory-routes": {
        "ClusterId": "inventory-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://auth-api:8080" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://inventory-api:8080" }
        }
      }
    }
  }
}