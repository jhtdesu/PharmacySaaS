{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-routes": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Hosts": [ "api.jhtdesu-app.tech" ],
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "tenant-routes": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Hosts": [ "api.jhtdesu-app.tech" ],
          "Path": "/api/tenant/{**catch-all}"
        }
      },
      "momo-routes": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Hosts": [ "api.jhtdesu-app.tech" ],
          "Path": "/api/momo/{**catch-all}"
        }
      },
      "medicines-routes": {
        "ClusterId": "inventory-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Hosts": [ "api.jhtdesu-app.tech" ],
          "Path": "/api/medicines/{**catch-all}"
        }
      },
      "sales-routes": {
        "ClusterId": "inventory-cluster",
        "CorsPolicy": "default", 
        "Match": {
          "Hosts": [ "api.jhtdesu-app.tech" ],
          "Path": "/api/sales/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://auth-api:8080" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://inventory-api:8080" }
        }
      }
    }
  }
}